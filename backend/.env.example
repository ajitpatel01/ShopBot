# AI
GROQ_API_KEY=                    # Get from console.groq.com

# Database
SUPABASE_URL=                    # Project URL from supabase.com > Settings > API
SUPABASE_ANON_KEY=               # anon public key
SUPABASE_SERVICE_KEY=            # service_role key — never expose to frontend

# Email
RESEND_API_KEY=                  # Get from resend.com

# Payments
RAZORPAY_KEY_ID=                 # Test key from razorpay.com > Settings > API Keys
RAZORPAY_SECRET=                 # Test secret
RAZORPAY_WEBHOOK_SECRET=         # Set in Churn 6
RAZORPAY_PLAN_STARTER=           # Set in Churn 6
RAZORPAY_PLAN_GROWTH=            # Set in Churn 6
RAZORPAY_PLAN_MULTISHOP=         # Set in Churn 6

# App
PORT=3001
NODE_ENV=development
DASHBOARD_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001
NGROK_URL=                       # Set in Churn 2 when running ngrok

# Test Data (Churn 3)
TEST_SHOP_NUMBER=                # Your connected WhatsApp number (e.g. +919876543210)
TEST_OWNER_NUMBER=               # Your personal number for owner notifications
TEST_OWNER_ID=                   # Supabase auth user UUID for seed script owner_id
